# Audio
aaudio.mmap_exclusive_policy=2
aaudio.mmap_policy=2
persist.audio.button_jack.profile=volume
persist.audio.button_jack.switch=0
ro.audio.monitorRotation=true
ro.vendor.audio.bluetooth.support.misound=false
ro.vendor.audio.misound.headset.only=true
ro.vendor.audio.scenario.support=true
ro.vendor.audio.sfx.earadj=true
ro.vendor.audio.sfx.scenario=flase
ro.vendor.audio.sos=true
ro.vendor.audio.soundfx.type=mi
ro.vendor.audio.soundfx.usb=true
ro.vendor.audio.spk.stereo=true
ro.vendor.audio.surround.support=true
ro.vendor.audio.us.proximity=true
ro.vendor.audio.vocal.support=true
ro.vendor.audio.voice.change.support=true
ro.vendor.audio.voice.volume.boost=manual
vendor.audio.powerhal.power.dl=true
vendor.audio.timecheck_timeoutMs=10000

# Bluetooth
bluetooth.profile.sap.server.enabled=true
persist.bluetooth.a2dp_offload.disabled=false
persist.bluetooth.disableinbandringing=true
ro.vendor.bluetooth.wipower=false
vendor.bluetooth.ldac.abr=true

# Camera
camera.disable_zsl_mode=1
vendor.camera.mdp.cz.enable=1
vendor.camera.mdp.dre.enable=1

# Display
debug.sf.cpupolicy.legacy=1
debug.sf.disable_backpressure=1
debug.sf.early.app.duration=20000000
debug.sf.early.sf.duration=27600000
debug.sf.earlyGl.app.duration=20000000
debug.sf.earlyGl.sf.duration=27600000
debug.sf.enable_gl_backpressure=0
debug.sf.enable_hwc_vds=0
debug.sf.hwc.min.duration=2000000
debug.sf.late.app.duration=20000000
debug.sf.late.sf.duration=27600000
debug.sf.region_sampling_period_ns=200000000
debug.sf.region_sampling_timer_timeout_ns=200000000
debug.sf.set_idle_timer_ms=3000
debug.sf.use_phase_offsets_as_durations=1
persist.displayfeature.dc_backlight.enable=false
persist.vendor.dc_backlight.enable=false
ro.gfx.driver.0=com.mediatek.mt6781.gamedriver
ro.hardware.egl=meow
ro.hardware.vulkan=mali
ro.opengles.version=196610
ro.surface_flinger.force_hwc_copy_for_virtual_displays=true
